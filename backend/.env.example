# Backend environment variables - copy to .env and never commit .env
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT=30/minute
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# Database configuration
# For Local Postgres (default):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/croked
# For SQLite (dev/testing):
# DATABASE_URL=sqlite:///./croked.db
# For Supabase Postgres:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT Security
JWT_SECRET=generaterandomstringhereinproduction

# Email (SMTP) — optional; without these, reset codes are logged to server console only
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-address@gmail.com
# EMAIL_PASS=your-app-password      # For Gmail: use an App Password, not your login password
# EMAIL_FROM=CROKED <your-address@gmail.com>
